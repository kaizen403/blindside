DATABASE_URL="postgresql://blindside:blindside_dev@localhost:5433/blindside"
DIRECT_URL="postgresql://blindside:blindside_dev@localhost:5433/blindside"
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Email provider: Azure Communication Services is preferred when configured.
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://...;accesskey=..."
EMAIL_FROM="Blindwall <reports@blindwall.app>"
EMAIL_REPLY_TO="hello@blindwall.app"
# Optional fallback only if Azure is not configured.
RESEND_API_KEY="***"
# Event Grid webhook URL after deploy: https://your-domain.com/api/webhooks/azure-email
NODE_ENV="development"
