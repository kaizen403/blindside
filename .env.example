DATABASE_URL="postgresql://blindside:***@localhost:5433/blindside"
DIRECT_URL="postgresql://blindside:***@localhost:5433/blindside"
BETTER_AUTH_SECRET="generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email provider: Azure Communication Services is preferred when configured.
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://...;accesskey=..."
EMAIL_FROM="Blindwall <reports@blindwall.tech>"
EMAIL_REPLY_TO="hello@blindwall.tech"

# Required for Event Grid webhook auth. Add it to the Event Grid endpoint as ?secret=<same-value>
AZURE_EVENT_GRID_WEBHOOK_SECRET="generate-a-random-webhook-secret"

# Optional fallback only if Azure is not configured.
RESEND_API_KEY="***"
NODE_ENV="development"
